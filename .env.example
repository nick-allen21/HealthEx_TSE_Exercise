# HealthEx FHIR base URL.
# Keep the public and server values aligned unless we intentionally split them later.
HEALTHEX_FHIR_BASE_URL=https://api.healthex.io/FHIR/R4
NEXT_PUBLIC_FHIR_BASE_URL=https://api.healthex.io/FHIR/R4

# Optional explicit Person ID override for helper scripts.
# If blank, the current browser token JWT `sub` is the default lookup handle.
HEALTHEX_PERSON_ID=

# Legacy fallback name used by older helper code. Prefer HEALTHEX_PERSON_ID.
HEALTHEX_PATIENT_ID=

# Optional placeholders for future authenticated workflows.
# The current app primarily uses a browser-pasted patient token in the live viewer.
HEALTHEX_API_KEY=
HEALTHEX_ACCESS_TOKEN=
NICK_HEALTHEX_AUTH=

# Server-side only. Used for the streamed chart summary route.
OPENAI_API_KEY=
