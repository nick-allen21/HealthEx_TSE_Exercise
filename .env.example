# HealthEx FHIR base URL.
# Keep the public and server values aligned unless we intentionally split them later.
HEALTHEX_FHIR_BASE_URL=https://api.healthex.io/FHIR/R4
NEXT_PUBLIC_FHIR_BASE_URL=https://api.healthex.io/FHIR/R4

# Fill this in once we select the demo patient record.
HEALTHEX_PATIENT_ID=

# Optional placeholders for future authenticated workflows.
# Leave blank unless the chosen HealthEx flow requires them.
HEALTHEX_API_KEY=
HEALTHEX_ACCESS_TOKEN=
